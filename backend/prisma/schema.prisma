generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  customer
  account_manager
  admin
}

enum AccountType {
  savings
  current
}

enum AccountStatus {
  active
  frozen
  closed
}

enum CardStatus {
  active
  frozen
  closed
}

enum TransactionType {
  deposit
  transfer
  transfer_external
  topup
  spend
  withdrawal
}

enum RequestType {
  open_account
  close_account
  freeze_account
  unfreeze_account
  issue_debit_card
  close_debit_card
  freeze_debit_card
  unfreeze_debit_card
  issue_credit_card
  close_credit_card
  freeze_credit_card
  unfreeze_credit_card
  increase_credit_limit
  decrease_credit_limit
  withdraw_money
}

enum RequestStatus {
  pending
  approved
  rejected
  cancelled
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  fullName     String   @map("full_name")
  createdAt    DateTime @default(now()) @map("created_at")

  customerAssignment CustomerAssignment?  @relation("CustomerAssignment")
  managerAssignments CustomerAssignment[] @relation("ManagerAssignment")
  bankAccounts       BankAccount[]
  debitCards         DebitCard[]
  creditCards        CreditCard[]
  customerRequests   Request[]            @relation("CustomerRequests")
  managerRequests    Request[]            @relation("ManagerRequests")

  @@map("users")
}

model CustomerAssignment {
  customerId       String @id @map("customer_id")
  accountManagerId String @map("account_manager_id")

  customer       User @relation("CustomerAssignment", fields: [customerId], references: [id], onDelete: Cascade)
  accountManager User @relation("ManagerAssignment", fields: [accountManagerId], references: [id])

  @@map("customer_assignments")
}

model BankAccount {
  id         String        @id @default(uuid())
  customerId String        @map("customer_id")
  iban       String        @unique
  type       AccountType
  status     AccountStatus @default(active)
  balance    Decimal       @default(0) @db.Decimal(15, 2)
  createdAt  DateTime      @default(now()) @map("created_at")

  customer     User          @relation(fields: [customerId], references: [id])
  debitCards   DebitCard[]
  outgoingTxns Transaction[] @relation("FromAccount")
  incomingTxns Transaction[] @relation("ToAccount")

  @@map("bank_accounts")
}

model DebitCard {
  id            String     @id @default(uuid())
  bankAccountId String     @map("bank_account_id")
  customerId    String     @map("customer_id")
  status        CardStatus @default(active)
  createdAt     DateTime   @default(now()) @map("created_at")

  bankAccount BankAccount   @relation(fields: [bankAccountId], references: [id])
  customer    User          @relation(fields: [customerId], references: [id])
  topupTxns   Transaction[] @relation("FromDebitCard")
  spendTxns   Transaction[] @relation("SpendDebitCard")

  @@map("debit_cards")
}

model CreditCard {
  id                 String     @id @default(uuid())
  customerId         String     @map("customer_id")
  status             CardStatus @default(active)
  creditLimit        Decimal    @map("credit_limit") @db.Decimal(15, 2)
  outstandingBalance Decimal    @default(0) @map("outstanding_balance") @db.Decimal(15, 2)
  createdAt          DateTime   @default(now()) @map("created_at")

  customer  User          @relation(fields: [customerId], references: [id])
  topupTxns Transaction[] @relation("ToCreditCard")

  @@map("credit_cards")
}

model Transaction {
  id            String          @id @default(uuid())
  type          TransactionType
  fromAccountId String?         @map("from_account_id")
  toAccountId   String?         @map("to_account_id")
  // fromCardId: debit card used as top-up source
  fromCardId    String?         @map("from_card_id")
  // toCardId: credit card receiving a top-up
  toCardId      String?         @map("to_card_id")
  // debitCardId: debit card used when spending (draws from linked account)
  debitCardId   String?         @map("debit_card_id")
  amount        Decimal         @db.Decimal(15, 2)
  description   String?
  createdAt     DateTime        @default(now()) @map("created_at")

  fromAccount BankAccount? @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount   BankAccount? @relation("ToAccount", fields: [toAccountId], references: [id])
  fromCard    DebitCard?   @relation("FromDebitCard", fields: [fromCardId], references: [id])
  toCard      CreditCard?  @relation("ToCreditCard", fields: [toCardId], references: [id])
  debitCard   DebitCard?   @relation("SpendDebitCard", fields: [debitCardId], references: [id])

  @@map("transactions")
}

model Request {
  id               String        @id @default(uuid())
  customerId       String        @map("customer_id")
  accountManagerId String?       @map("account_manager_id")
  type             RequestType
  status           RequestStatus @default(pending)
  payload          Json
  rejectionReason  String?       @map("rejection_reason")
  createdAt        DateTime      @default(now()) @map("created_at")
  actionedAt       DateTime?     @map("actioned_at")

  customer       User  @relation("CustomerRequests", fields: [customerId], references: [id])
  accountManager User? @relation("ManagerRequests", fields: [accountManagerId], references: [id])

  @@map("requests")
}
